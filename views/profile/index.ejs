<%- include('../partials/head', { title }) %>
<%- include('../partials/header') %>

<main class="container page-section narrow">
  <h1>Профиль</h1>
  <%- include('../partials/flash') %>

  <section class="profile-hero-card">
    <div class="profile-hero-head">
      <div>
        <h2><%= user.full_name %></h2>
        <p class="profile-muted">Ваш личный кабинет и история покупок</p>
      </div>
      <span class="badge"><%= user.role === 'admin' ? 'Администратор' : 'Покупатель' %></span>
    </div>

    <div class="profile-stats-grid">
      <article class="profile-stat-card">
        <p class="profile-stat-label">Всего заказов</p>
        <p class="profile-stat-value"><%= stats.totalOrders %></p>
      </article>
      <article class="profile-stat-card">
        <p class="profile-stat-label">Потрачено</p>
        <p class="profile-stat-value"><%= Number(stats.totalSpent).toLocaleString('ru-RU') %> ₽</p>
      </article>
      <article class="profile-stat-card">
        <p class="profile-stat-label">Последний заказ</p>
        <% if (stats.lastOrder) { %>
          <p class="profile-stat-value">#<%= stats.lastOrder.id %></p>
          <p class="profile-muted"><%= new Date(stats.lastOrder.created_at).toLocaleDateString('ru-RU') %></p>
        <% } else { %>
          <p class="profile-stat-value">—</p>
          <p class="profile-muted">Пока нет заказов</p>
        <% } %>
      </article>
    </div>
  </section>

  <div class="form-card profile-details-card">
    <h3>Контактные данные</h3>
    <div class="profile-details-grid">
      <p><strong>Email:</strong> <%= user.email %></p>
      <p><strong>Телефон:</strong> <%= user.phone || '—' %></p>
      <p class="profile-address"><strong>Адрес:</strong> <%= user.address || '—' %></p>
    </div>
    <div class="actions-row">
      <a href="/profile/edit" class="btn btn-secondary">Редактировать профиль</a>
      <a href="/profile/orders" class="btn">История заказов</a>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
