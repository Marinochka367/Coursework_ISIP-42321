<%- include('../partials/head', { title }) %>
<%- include('../partials/header') %>

<main class="container page-section">
  <h1>Управление акциями</h1>
  <%- include('../partials/flash') %>

  <div class="admin-nav">
    <a class="category-chip" href="/admin">Дашборд</a>
    <a class="category-chip" href="/admin/categories">Категории</a>
    <a class="category-chip" href="/admin/products">Товары</a>
    <a class="category-chip active" href="/admin/promotions">Акции</a>
    <a class="category-chip" href="/admin/orders">Заказы</a>
  </div>

  <div class="admin-layout">
    <form action="<%= editItem ? `/admin/promotions/${editItem.id}` : '/admin/promotions' %>" method="POST" class="form-card">
      <h2><%= editItem ? 'Редактировать акцию' : 'Новая акция' %></h2>
      <label>Название <input type="text" name="title" value="<%= editItem?.title || '' %>" required /></label>
      <label>Описание <textarea name="description" rows="5" required><%= editItem?.description || '' %></textarea></label>
      <label>Промокод <input type="text" name="promoCode" value="<%= editItem?.promo_code || '' %>" /></label>
      <label>
        Тип скидки
        <select name="discountType">
          <option value="percent" <%= editItem?.discount_type === 'percent' ? 'selected' : '' %>>Процент</option>
          <option value="fixed" <%= editItem?.discount_type === 'fixed' ? 'selected' : '' %>>Фиксированная</option>
        </select>
      </label>
      <label>Значение скидки <input type="number" step="0.01" name="discountValue" value="<%= editItem?.discount_value || '' %>" required /></label>
      <label>
        Товар (необязательно)
        <select name="productId">
          <option value="">Вся корзина / все товары</option>
          <% products.forEach((product) => { %>
            <option value="<%= product.id %>" <%= Number(editItem?.product_id) === Number(product.id) ? 'selected' : '' %>><%= product.name %></option>
          <% }) %>
        </select>
      </label>
      <label>Дата начала <input type="datetime-local" name="startsAt" value="<%= editItem?.starts_at || '' %>" required /></label>
      <label>Дата окончания <input type="datetime-local" name="endsAt" value="<%= editItem?.ends_at || '' %>" required /></label>
      <label>
        Статус
        <select name="isActive">
          <option value="1" <%= String(editItem?.is_active ?? 1) === '1' ? 'selected' : '' %>>Активна</option>
          <option value="0" <%= String(editItem?.is_active ?? 1) === '0' ? 'selected' : '' %>>Отключена</option>
        </select>
      </label>
      <button type="submit" class="btn"><%= editItem ? 'Сохранить' : 'Создать' %></button>
      <% if (editItem) { %><a href="/admin/promotions" class="btn btn-secondary">Отмена</a><% } %>
    </form>

    <div class="summary-card">
      <div class="section-header">
        <h2>Список акций</h2>
        <form method="GET" action="/admin/promotions" class="search-form">
          <input type="text" name="search" placeholder="Поиск по названию, промокоду, товару" value="<%= filters.search %>" />
          <button type="submit" class="btn btn-secondary">Найти</button>
        </form>
      </div>
      <div class="table-wrap">
        <table class="admin-table">
          <thead><tr><th>ID</th><th>Название</th><th>Промокод</th><th>Скидка</th><th>Товар</th><th>Период</th><th>Статус</th><th>Действия</th></tr></thead>
          <tbody>
            <% promotions.forEach((item) => { %>
              <tr>
                <td><%= item.id %></td>
                <td><%= item.title %></td>
                <td><%= item.promo_code || '—' %></td>
                <td><%= item.discount_type === 'percent' ? `${item.discount_value}%` : `${Number(item.discount_value).toLocaleString('ru-RU')} ₽` %></td>
                <td><%= item.product_name || 'Все товары' %></td>
                <td><%= new Date(item.starts_at).toLocaleDateString('ru-RU') %> — <%= new Date(item.ends_at).toLocaleDateString('ru-RU') %></td>
                <td><%= item.is_active ? 'Активна' : 'Отключена' %></td>
                <td class="actions-cell">
                  <a class="btn btn-secondary" href="/admin/promotions/<%= item.id %>/edit?search=<%= encodeURIComponent(filters.search || '') %>&page=<%= pagination.currentPage %>">Изменить</a>
                  <form action="/admin/promotions/<%= item.id %>/delete" method="POST" class="inline-form">
                    <button type="submit" class="btn btn-danger">Удалить</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <% if (!promotions.length) { %><p>Акции не найдены.</p><% } %>

      <div class="pagination">
        <% pagination.pages.forEach((pageNumber) => { %>
          <a href="/admin/promotions?page=<%= pageNumber %>&search=<%= encodeURIComponent(filters.search || '') %>" class="category-chip <%= pagination.currentPage === pageNumber ? 'active' : '' %>"><%= pageNumber %></a>
        <% }) %>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
