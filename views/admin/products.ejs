<%- include('../partials/head', { title }) %>
<%- include('../partials/header') %>

<main class="container page-section">
  <h1>Управление товарами</h1>
  <%- include('../partials/flash') %>

  <div class="admin-nav">
    <a class="category-chip" href="/admin">Дашборд</a>
    <a class="category-chip" href="/admin/categories">Категории</a>
    <a class="category-chip active" href="/admin/products">Товары</a>
    <a class="category-chip" href="/admin/promotions">Акции</a>
    <a class="category-chip" href="/admin/orders">Заказы</a>
  </div>

  <div class="admin-layout">
    <form action="<%= editItem ? `/admin/products/${editItem.id}` : '/admin/products' %>" method="POST" enctype="multipart/form-data" class="form-card">
      <h2><%= editItem ? 'Редактировать товар' : 'Новый товар' %></h2>
      <label>
        Категория
        <select name="categoryId" required>
          <% categories.forEach((category) => { %>
            <option value="<%= category.id %>" <%= Number(editItem?.category_id) === Number(category.id) ? 'selected' : '' %>><%= category.name %></option>
          <% }) %>
        </select>
      </label>
      <label>Название <input type="text" name="name" value="<%= editItem?.name || '' %>" required /></label>
      <label>Slug <input type="text" name="slug" value="<%= editItem?.slug || '' %>" required /></label>
      <label>Цена <input type="number" step="0.01" name="price" value="<%= editItem?.price || '' %>" required /></label>
      <label>Описание <textarea name="description" rows="5" required><%= editItem?.description || '' %></textarea></label>
      <label>Остаток <input type="number" name="stock" min="0" value="<%= editItem?.stock ?? 0 %>" required /></label>
      <label>
        Статус
        <select name="isActive">
          <option value="1" <%= String(editItem?.is_active ?? 1) === '1' ? 'selected' : '' %>>Активен</option>
          <option value="0" <%= String(editItem?.is_active ?? 1) === '0' ? 'selected' : '' %>>Скрыт</option>
        </select>
      </label>
      <% if (editItem?.image) { %><p>Текущее изображение: <code><%= editItem.image %></code></p><% } %>
      <label>Изображение <input type="file" name="image" <%= editItem ? '' : 'required' %> accept=".jpg,.jpeg,.png,.webp" /></label>
      <button type="submit" class="btn"><%= editItem ? 'Сохранить' : 'Создать' %></button>
      <% if (editItem) { %><a href="/admin/products" class="btn btn-secondary">Отмена</a><% } %>
    </form>

    <div class="summary-card">
      <div class="section-header">
        <h2>Список товаров</h2>
        <form method="GET" action="/admin/products" class="search-form">
          <input type="text" name="search" placeholder="Поиск по названию, slug, категории" value="<%= filters.search %>" />
          <button type="submit" class="btn btn-secondary">Найти</button>
        </form>
      </div>

      <div class="table-wrap">
        <table class="admin-table">
          <thead><tr><th>ID</th><th>Фото</th><th>Название</th><th>Категория</th><th>Цена</th><th>Остаток</th><th>Статус</th><th>Действия</th></tr></thead>
          <tbody>
            <% products.forEach((item) => { %>
              <tr>
                <td><%= item.id %></td>
                <td><img src="<%= item.image %>" alt="<%= item.name %>" class="admin-thumb" /></td>
                <td><%= item.name %></td>
                <td><%= item.category_name %></td>
                <td><%= Number(item.price).toLocaleString('ru-RU') %> ₽</td>
                <td><%= item.stock %></td>
                <td><%= item.is_active ? 'Активен' : 'Скрыт' %></td>
                <td class="actions-cell">
                  <a class="btn btn-secondary" href="/admin/products/<%= item.id %>/edit?search=<%= encodeURIComponent(filters.search || '') %>&page=<%= pagination.currentPage %>">Изменить</a>
                  <form action="/admin/products/<%= item.id %>/delete" method="POST" class="inline-form">
                    <button type="submit" class="btn btn-danger">Удалить</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <% if (!products.length) { %><p>Товары не найдены.</p><% } %>

      <div class="pagination">
        <% pagination.pages.forEach((pageNumber) => { %>
          <a href="/admin/products?page=<%= pageNumber %>&search=<%= encodeURIComponent(filters.search || '') %>" class="category-chip <%= pagination.currentPage === pageNumber ? 'active' : '' %>"><%= pageNumber %></a>
        <% }) %>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
