<%- include('../partials/head', { title }) %>
<%- include('../partials/header') %>

<main class="container page-section">
  <h1>Управление заказами</h1>
  <%- include('../partials/flash') %>

  <div class="admin-nav">
    <a class="category-chip" href="/admin">Дашборд</a>
    <a class="category-chip" href="/admin/categories">Категории</a>
    <a class="category-chip" href="/admin/products">Товары</a>
    <a class="category-chip" href="/admin/promotions">Акции</a>
    <a class="category-chip active" href="/admin/orders">Заказы</a>
  </div>

  <div class="admin-layout-wide">
    <div class="summary-card">
      <div class="section-header">
        <h2>Список заказов</h2>
        <form method="GET" action="/admin/orders" class="search-form search-form-wide">
          <input type="text" name="search" placeholder="Поиск по ID, имени, email" value="<%= filters.search %>" />
          <select name="status">
            <option value="">Все статусы</option>
            <% statuses.forEach((itemStatus) => { %>
              <option value="<%= itemStatus %>" <%= filters.status === itemStatus ? 'selected' : '' %>><%= itemStatus %></option>
            <% }) %>
          </select>
          <button type="submit" class="btn btn-secondary">Фильтр</button>
        </form>
      </div>

      <div class="table-wrap">
        <table class="admin-table">
          <thead><tr><th>ID</th><th>Клиент</th><th>Email</th><th>Статус</th><th>Оплата</th><th>Позиций</th><th>Сумма</th><th>Дата</th><th>Действия</th></tr></thead>
          <tbody>
            <% orders.forEach((order) => { %>
              <tr>
                <td>#<%= order.id %></td>
                <td><%= order.customer_name %></td>
                <td><%= order.customer_email %></td>
                <td><span class="badge"><%= order.status %></span></td>
                <td><%= order.payment_method %></td>
                <td><%= order.items_count %></td>
                <td><%= Number(order.total_amount).toLocaleString('ru-RU') %> ₽</td>
                <td><%= new Date(order.created_at).toLocaleString('ru-RU') %></td>
                <td><a class="btn btn-secondary" href="/admin/orders/<%= order.id %>?search=<%= encodeURIComponent(filters.search || '') %>&status=<%= encodeURIComponent(filters.status || '') %>&page=<%= pagination.currentPage %>">Открыть</a></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <% if (!orders.length) { %><p>Заказы не найдены.</p><% } %>

      <div class="pagination">
        <% pagination.pages.forEach((pageNumber) => { %>
          <a href="/admin/orders?page=<%= pageNumber %>&search=<%= encodeURIComponent(filters.search || '') %>&status=<%= encodeURIComponent(filters.status || '') %>" class="category-chip <%= pagination.currentPage === pageNumber ? 'active' : '' %>"><%= pageNumber %></a>
        <% }) %>
      </div>
    </div>

    <div class="summary-card">
      <% if (!activeOrder) { %>
        <h2>Детали заказа</h2>
        <p>Выберите заказ из списка, чтобы посмотреть состав, контакты и изменить статус.</p>
      <% } else { %>
        <h2>Заказ #<%= activeOrder.id %></h2>
        <p><strong>Клиент:</strong> <%= activeOrder.customer_name %></p>
        <p><strong>Email:</strong> <%= activeOrder.customer_email %></p>
        <p><strong>Телефон:</strong> <%= activeOrder.customer_phone %></p>
        <p><strong>Пользователь:</strong> <%= activeOrder.user_name %> (<%= activeOrder.user_email %>)</p>
        <p><strong>Адрес доставки:</strong> <%= activeOrder.delivery_address %></p>
        <p><strong>Оплата:</strong> <%= activeOrder.payment_method %></p>
        <p><strong>Промокод:</strong> <%= activeOrder.promo_code || '—' %></p>
        <p><strong>Дата:</strong> <%= new Date(activeOrder.created_at).toLocaleString('ru-RU') %></p>
        <% if (activeOrder.notes) { %><p><strong>Комментарий:</strong> <%= activeOrder.notes %></p><% } %>

        <form action="/admin/orders/<%= activeOrder.id %>/status" method="POST" class="form-card compact-form">
          <label>
            Статус заказа
            <select name="status">
              <% statuses.forEach((itemStatus) => { %>
                <option value="<%= itemStatus %>" <%= activeOrder.status === itemStatus ? 'selected' : '' %>><%= itemStatus %></option>
              <% }) %>
            </select>
          </label>
          <button type="submit" class="btn">Сохранить статус</button>
        </form>

        <h3>Состав заказа</h3>
        <ul>
          <% activeOrder.items.forEach((item) => { %>
            <li><%= item.product_name %> — <%= item.quantity %> × <%= Number(item.unit_price).toLocaleString('ru-RU') %> ₽ = <%= Number(item.line_total).toLocaleString('ru-RU') %> ₽</li>
          <% }) %>
        </ul>

        <div class="summary-card nested-summary">
          <div class="summary-row"><span>Подытог</span><strong><%= Number(activeOrder.subtotal).toLocaleString('ru-RU') %> ₽</strong></div>
          <div class="summary-row"><span>Скидка</span><strong><%= Number(activeOrder.discount_amount).toLocaleString('ru-RU') %> ₽</strong></div>
          <div class="summary-row"><span>Итого</span><strong><%= Number(activeOrder.total_amount).toLocaleString('ru-RU') %> ₽</strong></div>
        </div>
      <% } %>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
