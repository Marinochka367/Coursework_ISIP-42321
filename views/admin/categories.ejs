<%- include('../partials/head', { title }) %>
<%- include('../partials/header') %>

<main class="container page-section">
  <h1>Управление категориями</h1>
  <%- include('../partials/flash') %>

  <div class="admin-nav">
    <a class="category-chip" href="/admin">Дашборд</a>
    <a class="category-chip active" href="/admin/categories">Категории</a>
    <a class="category-chip" href="/admin/products">Товары</a>
    <a class="category-chip" href="/admin/promotions">Акции</a>
    <a class="category-chip" href="/admin/orders">Заказы</a>
  </div>

  <div class="admin-layout">
    <form action="<%= editItem ? `/admin/categories/${editItem.id}` : '/admin/categories' %>" method="POST" class="form-card">
      <h2><%= editItem ? 'Редактировать категорию' : 'Новая категория' %></h2>
      <label>Название <input type="text" name="name" value="<%= editItem?.name || '' %>" required /></label>
      <label>Slug <input type="text" name="slug" value="<%= editItem?.slug || '' %>" required /></label>
      <button type="submit" class="btn"><%= editItem ? 'Сохранить' : 'Создать' %></button>
      <% if (editItem) { %><a href="/admin/categories" class="btn btn-secondary">Отмена</a><% } %>
    </form>

    <div class="summary-card">
      <div class="section-header">
        <h2>Список категорий</h2>
        <form method="GET" action="/admin/categories" class="search-form">
          <input type="text" name="search" placeholder="Поиск по названию или slug" value="<%= filters.search %>" />
          <button type="submit" class="btn btn-secondary">Найти</button>
        </form>
      </div>

      <div class="table-wrap">
        <table class="admin-table">
          <thead><tr><th>ID</th><th>Название</th><th>Slug</th><th>Действия</th></tr></thead>
          <tbody>
            <% categories.forEach((item) => { %>
              <tr>
                <td><%= item.id %></td>
                <td><%= item.name %></td>
                <td><%= item.slug %></td>
                <td class="actions-cell">
                  <a class="btn btn-secondary" href="/admin/categories/<%= item.id %>/edit?search=<%= encodeURIComponent(filters.search || '') %>&page=<%= pagination.currentPage %>">Изменить</a>
                  <form action="/admin/categories/<%= item.id %>/delete" method="POST" class="inline-form">
                    <button type="submit" class="btn btn-danger">Удалить</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <% if (!categories.length) { %><p>Категории не найдены.</p><% } %>

      <div class="pagination">
        <% pagination.pages.forEach((pageNumber) => { %>
          <a href="/admin/categories?page=<%= pageNumber %>&search=<%= encodeURIComponent(filters.search || '') %>" class="category-chip <%= pagination.currentPage === pageNumber ? 'active' : '' %>"><%= pageNumber %></a>
        <% }) %>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
