<%- include('../partials/head', { title }) %>
<%- include('../partials/header') %>

<main class="container page-section narrow">
  <h1>Заказ успешно оформлен</h1>
  <%- include('../partials/flash') %>
  <div class="summary-card">
    <p>Номер заказа: <strong>#<%= order.id %></strong></p>
    <p>Статус: <strong><%= order.status %></strong></p>
    <p>Итого: <strong><%= Number(order.total_amount).toLocaleString('ru-RU') %> ₽</strong></p>
    <p>Адрес доставки: <%= order.delivery_address %></p>
    <a href="/profile/orders" class="btn">Перейти к истории заказов</a>
  </div>
</main>

<%- include('../partials/footer') %>
